{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend/src/*"]
    },
    "sourceMap": true,
    "types": ["vite/client"]
  },
  "include": ["frontend/src/**/*"],
  "exclude": ["node_modules"]
}
