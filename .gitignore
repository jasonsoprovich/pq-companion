# ── SQL dumps (large, not source code) ────────────────────────────────────────
/sql/*.sql
!sql/example_queries.sql

# ── Task docs (distilled into FEATURES.md) ────────────────────────────────────
# Ignore everything under /docs/ except the persistent reference docs we
# intentionally keep in tree. A parent-level `/docs/` rule would hide the
# whole directory and make `!` exceptions unreachable, so ignore contents instead.
/docs/*
!/docs/db-pipeline.md
!/docs/enum-audit.md
!/docs/database-test-plan.md
!/docs/issue-123-divergence-triage-plan.md
!/docs/trigger-pack-rollback-2026-06-10.md
!/docs/cloud-tts-plan.md
!/docs/legacy-packs-2026-06-10/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer

# ── SQLite databases (generated artifacts) ────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Go ────────────────────────────────────────────────────────────────────────
backend/bin/
/bin/
*.exe
*.exe~

# ── Node / frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ── Electron build output ─────────────────────────────────────────────────────
electron/dist/
dist/
release/
out/
*.dmg
*.AppImage
*.deb
*.rpm
*.snap

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
*.swp
*.swo
*~
.claude/

# ── Test Logs from game (all files found within /TAKPv22/ root directory) ────────────────────────────────────
testdata/

# Synthetic, hand-authored fixtures that MUST be committed (not real game logs).
# Re-include the dir, re-ignore its contents, then un-ignore the specific file.
!backend/internal/lockout/testdata/
backend/internal/lockout/testdata/*
!backend/internal/lockout/testdata/sll-sample.log
